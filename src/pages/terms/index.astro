---
import { Button, CardList } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ, terms } from '@/site-config'

const meta = {
  title: '站点说明',
  description: '站点说明与使用约定'
}
---

<PageLayout {meta}>
  <Button title='返回' href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>站点说明</h1>
    </div>

    <div id='content' class={cn('animate mt-8 max-w-none md:min-w-[45ch]', integ.typography.class)}>
      <h2 class='text-xl font-medium'>站点文档</h2>
      <CardList {...terms} />
      <h2 class='text-xl font-medium'>补充说明</h2>
      <p>这里会放隐私、版权、转载和站点维护相关说明。</p>
    </div>
  </main>
</PageLayout>
