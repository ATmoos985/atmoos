---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'

import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import config from '@/site-config'

const MAX_THOUGHTS = 5
const MAX_NOTES = 6

const thoughts = sortMDByDate(await getBlogCollection()).slice(0, MAX_THOUGHTS)
const notes = (await getBlogCollection('docs')) as CollectionEntry<'docs'>[]

const noteMeta: Record<string, { title: string; summary: string; accent: string }> = {
  setup: {
    title: '建站与配置',
    summary: '站点搭建、内容写作和发布流程。',
    accent: 'border-sky-400'
  },
  integrations: {
    title: '功能组件',
    summary: '评论、搜索、展示组件和交互增强。',
    accent: 'border-emerald-400'
  },
  advanced: {
    title: '维护优化',
    summary: '性能、主题、升级和长期维护。',
    accent: 'border-rose-400'
  }
}
const noteOrder = Object.keys(noteMeta)

const getNoteTime = (note: CollectionEntry<'docs'>) =>
  new Date(note.data.updatedDate ?? note.data.publishDate ?? 0).valueOf()

const recentNotes = [...notes]
  .sort((a, b) => getNoteTime(b) - getNoteTime(a) || a.data.order - b.data.order)
  .slice(0, MAX_NOTES)

const noteGroups = notes.reduce<Record<string, CollectionEntry<'docs'>[]>>((acc, note) => {
  const group = note.id.split('/')[0] ?? 'misc'
  acc[group] ??= []
  acc[group].push(note)
  return acc
}, {})

const noteCategories = Object.entries(noteGroups)
  .map(([id, items]) => ({
    id,
    items: items.sort((a, b) => a.data.order - b.data.order),
    ...(noteMeta[id] ?? {
      title: id,
      summary: '持续整理中的笔记分组。',
      accent: 'border-muted-foreground'
    })
  }))
  .sort((a, b) => {
    const aOrder = noteOrder.includes(a.id) ? noteOrder.indexOf(a.id) : 999
    const bOrder = noteOrder.includes(b.id) ? noteOrder.indexOf(b.id) : 999
    return aOrder - bOrder || a.title.localeCompare(b.title)
  })

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: '首页' }} highlightColor='#4F8F8A'>
  <main class='flex w-full flex-col items-center'>
    <section
      class='animate grid w-full items-center gap-8 py-10 md:grid-cols-[0.95fr_1.05fr] md:py-14'
      id='content-header'
    >
      <div class='flex flex-col gap-y-6'>
        <div class='flex flex-wrap gap-2'>
          <Label title='杂想' />
          <Label title='知识库' />
          <Label title='长期记录' />
        </div>
        <div class='max-w-2xl'>
          <p class='mb-3 text-sm font-medium uppercase tracking-[0.24em] text-muted-foreground'>
            Atmoos Notebook
          </p>
          <h1 class='text-4xl font-medium leading-tight sm:text-5xl'>
            把零散想法留下来，把有用知识整理成树。
          </h1>
          <p class='mt-5 max-w-xl text-base leading-8 text-muted-foreground'>
            这里会同时保留两种记录：杂想是按时间流动的片段，笔记库是按主题沉淀的结构。
          </p>
        </div>
        <div class='flex flex-wrap gap-3'>
          <Button title='进入笔记库' href='/docs' variant='ahead' />
          <Button title='查看杂想' href='/blog' />
        </div>
      </div>

      <div class='justify-self-center md:justify-self-end'>
        <div class='relative grid size-52 place-items-center rounded-full border bg-muted/50 sm:size-64'>
          <div class='absolute inset-6 rounded-full border border-dashed border-muted-foreground/35'></div>
          <Image
            src={images[imagePath]()}
            alt={config.logo.alt || 'Profile'}
            class='size-32 rounded-full border bg-background object-cover p-1 shadow-sm sm:size-40'
            loading='eager'
            fetchpriority='high'
          />
        </div>
      </div>
    </section>

    <div id='content' class='animate flex w-full flex-col gap-y-12 md:w-5/6'>
      <section class='grid gap-4 md:grid-cols-3'>
        {
          noteCategories.map((category) => (
            <a
              href={`/docs/${category.items[0]?.id ?? ''}`}
              class={`rounded-lg border-l-4 bg-muted/35 px-5 py-4 transition-colors hover:bg-muted ${category.accent}`}
            >
              <p class='text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground'>
                {category.items.length} notes
              </p>
              <h2 class='mt-2 text-lg font-medium'>{category.title}</h2>
              <p class='mt-2 text-sm leading-6 text-muted-foreground'>{category.summary}</p>
            </a>
          ))
        }
      </section>

      <section class='grid gap-8 lg:grid-cols-[1.1fr_0.9fr]'>
        <div class='flex min-w-0 flex-col gap-y-4'>
          <div class='flex items-end justify-between gap-4'>
            <div>
              <h2 class='text-2xl font-medium'>最近杂想</h2>
              <p class='mt-1 text-sm text-muted-foreground'>按时间记录的想法、文章和片段。</p>
            </div>
            <Button title='全部' href='/blog' />
          </div>
          {
            thoughts.length > 0 ? (
              <ul class='flex flex-col gap-y-3'>
                {thoughts.map((post) => (
                  <PostPreview post={post} />
                ))}
              </ul>
            ) : (
              <p class='rounded-lg border px-4 py-3 text-muted-foreground'>暂无杂想。</p>
            )
          }
        </div>

        <div class='flex min-w-0 flex-col gap-y-4'>
          <div class='flex items-end justify-between gap-4'>
            <div>
              <h2 class='text-2xl font-medium'>最近更新的笔记</h2>
              <p class='mt-1 text-sm text-muted-foreground'>从树形笔记库里抽出的最新条目。</p>
            </div>
            <Button title='目录' href='/docs' />
          </div>
          <ol class='flex flex-col gap-y-2'>
            {
              recentNotes.map((note) => (
                <li>
                  <a
                    href={`/docs/${note.id}`}
                    class='group flex items-start gap-3 rounded-lg border px-4 py-3 transition-colors hover:bg-muted/40'
                  >
                    <span class='mt-1 flex size-6 shrink-0 items-center justify-center rounded-full bg-muted text-xs text-muted-foreground group-hover:text-foreground'>
                      <Icon name='document' class='size-4' />
                    </span>
                    <span class='min-w-0'>
                      <span class='block font-medium'>{note.data.title}</span>
                      <span class='mt-1 block line-clamp-2 text-sm leading-6 text-muted-foreground'>
                        {note.data.description}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ol>
        </div>
      </section>
    </div>
  </main>
</PageLayout>
