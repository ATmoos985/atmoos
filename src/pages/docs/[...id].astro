---
import { type CollectionEntry, render } from 'astro:content'

import { MediumZoom } from 'astro-pure/advanced'
import { TOC } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/ContentLayout.astro'

import DocsContents from '@/components/docs/DocsContents.astro'

export const prerender = true

export async function getStaticPaths() {
  const posts = sortMDByDate(await getBlogCollection('docs'))
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post }
  }))
}

type Props = {
  post: CollectionEntry<'docs'>
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const { description, title } = post.data

const categoryLabels: Record<string, string> = {
  setup: '建站与配置',
  integrations: '功能组件',
  advanced: '维护优化'
}
const pathParts = post.id.split('/')
const category = pathParts[0] ?? 'notes'
const categoryTitle = categoryLabels[category] ?? category
---

<PageLayout meta={{ description, title }} back='/docs'>
  <Fragment slot='sidebar'>
    {!!headings.length && <TOC {headings} />}
    <DocsContents class='docs-toc mt-4 block' />
  </Fragment>

  <Fragment slot='header'>
    <div class='mb-4 flex flex-wrap items-center gap-2 text-xs text-muted-foreground'>
      <a href='/docs' class='hover:text-foreground'>笔记库</a>
      <span>/</span>
      <span>{categoryTitle}</span>
    </div>
    <h1 class='text-2xl font-medium sm:mb-2 sm:text-3xl'>
      {title}
    </h1>
    {
      description && (
        <blockquote class='mt-4 text-sm italic leading-7 text-muted-foreground'>
          <q>{description}</q>
        </blockquote>
      )
    }
  </Fragment>

  <Content />

  <div slot='bottom' class='flex flex-col gap-y-4'>
    <div class='rounded-lg border px-4 py-3 text-sm leading-7 text-muted-foreground'>
      当前路径：{['笔记库', categoryTitle, title].join(' / ')}
    </div>
    <Button title='回到笔记库' href='/docs' class='w-fit px-3 py-2' style='font-size:1rem' />
    <div class='rounded-lg border px-4 py-3 sm:py-4 md:mt-2'>
      <DocsContents />
    </div>
  </div>
</PageLayout>
<MediumZoom />

<style>
  @media (min-width: 1300px) {
    :global(
      main, .bottom { transform: translateX(7.9rem); }
      #sidebar { overflow: inherit; }
      toc-heading { height: 100%; display: flex; flex-direction: column; }
      toc-heading > ul { overflow-y: scroll; }
    )
    .docs-toc {
      position: fixed;
      top: 0;
      left: -64rem;
      margin-top: 0;
      max-height: calc(100vh - 7rem);
      overflow-y: scroll;
      padding-right: 1rem !important;
    }
  }
</style>
