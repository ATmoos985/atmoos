---
import { Button } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'

const headings = [
  { depth: 2, slug: 'site', text: '站点项目' },
  { depth: 2, slug: 'workflow', text: '写作工作流' },
  { depth: 2, slug: 'ideas', text: '待实现想法' }
]
---

<PageLayout title='项目' {headings} view>
  <p>
    这里暂时不放模板项目列表，而是记录这个个人站本身的建设过程，以及后续可能独立出来的小工具。
  </p>
  <div class='not-prose flex flex-wrap gap-3'>
    <Button title='查看笔记库' href='/docs' variant='ahead' />
    <Button title='查看杂想' href='/blog' />
  </div>

  <h2 id='site'>站点项目</h2>
  <ProjectSection
    projects={[
      {
        name: 'Atmoos 个人记录站',
        description: '把博客改造成杂想时间流和树形笔记库，作为公开的长期记录入口。',
        links: [
          { type: 'site', href: '/' },
          { type: 'doc', href: '/docs' }
        ]
      },
      {
        name: '笔记库结构化改造',
        description: '把原模板文档逐步替换成真实笔记，并按主题维护清晰目录。',
        links: [
          { type: 'doc', href: '/docs' },
          { type: 'site', href: '/search' }
        ]
      }
    ]}
  />

  <h2 id='workflow'>写作工作流</h2>
  <ProjectSection
    projects={[
      {
        name: '网页端写作入口',
        description: '规划一个轻量后台，支持在网页里写 Markdown 并发布到 Git 仓库。',
        links: [{ type: 'doc', href: '/docs/setup/content' }]
      },
      {
        name: '内容迁移清单',
        description: '把散落在本地、聊天记录和临时文件里的笔记逐步整理进站点。',
        links: [{ type: 'site', href: '/blog' }]
      }
    ]}
  />

  <h2 id='ideas'>待实现想法</h2>
  <ul>
    <li>给笔记库增加更清晰的二级目录和最近更新排序。</li>
    <li>增加网页端上传文章、上传图片和触发 Vercel 部署的后台。</li>
    <li>整理真实头像、社交链接、站点说明和内容版权页面。</li>
    <li>把模板示例文章逐步替换成自己的真实内容。</li>
  </ul>
</PageLayout>
